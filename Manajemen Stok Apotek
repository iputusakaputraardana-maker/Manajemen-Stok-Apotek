package main
import "fmt"

const NMAX int = 100

//Tipe data obat digunakan untuk menyimpan informasi setiap obat
type Obat struct {
	Nama  string
	Harga int
	Stok  int
}

//Tipe data transaksi digunakan untuk menyimpan data transaksi pembelian
type Transaksi struct {
	NamaObat string
	Jumlah   int
	Total    int
}

type ArrObat [NMAX]Obat
type ArrTransaksi [NMAX]Transaksi

// PROCEDURE / FUNCTION PENCARIAN

/* IS : Array obat A berisi n data obat dan nama yang dicari tersedia.
   FS : Mengembalikan indeks obat jika ditemukan, -1 jika tidak ditemukan.
*/
func sequentialSearch(A ArrObat, n int, nama string) int {
	var i, idx int
	idx = -1
	for i = 0; i < n; i++ {
		if A[i].Nama == nama {
			idx = i
		}
	}
	return idx
}

/* IS : Array obat A sudah terurut berdasarkan Nama, n > 0.
   FS : Mengembalikan indeks obat jika ditemukan, -1 jika tidak ditemukan. 
*/
func binarySearch(A ArrObat, n int, nama string) int {
	var kiri, kanan, tengah, idx int
	kiri = 0
	kanan = n - 1
	idx = -1

	for kiri <= kanan {
		tengah = (kiri + kanan) / 2

		if A[tengah].Nama == nama {
			idx = tengah
			kiri = kanan + 1
		} else if A[tengah].Nama < nama {
			kiri = tengah + 1
		} else {
			kanan = tengah - 1
		}
	}
	return idx
}

//PROCEDURE SORTING

/* IS : Array obat A berisi n data obat.
   FS : Data obat terurut menaik berdasarkan nama obat.
*/
func selectionSortNama(A *ArrObat, n int) {
	var i, j, min int
	var temp Obat
	for i = 0; i < n-1; i++ {
		min = i

		for j = i + 1; j < n; j++ {
			if A[j].Nama < A[min].Nama {
				min = j
			}
		}
		temp = A[i]
		A[i] = A[min]
		A[min] = temp
	}
}

/* IS : Array obat A berisi n data obat.
   FS : Data obat terurut menaik berdasarkan stok.
*/
func selectionSortStok(A *ArrObat, n int) {
	var i, j, min int
	var temp Obat
	for i = 0; i < n-1; i++ {
		min = i

		for j = i + 1; j < n; j++ {
			if A[j].Stok < A[min].Stok {
				min = j
			}
		}
		temp = A[i]
		A[i] = A[min]
		A[min] = temp
	}
}

/* IS : Array transaksi T berisi m data transaksi.
   FS : Data transaksi terurut menurun berdasarkan total transaksi.
*/
func insertionSortTransaksi(T *ArrTransaksi, m int) {
	var i, j int
	var temp Transaksi

	for i = 1; i < m; i++ {
		temp = T[i]
		j = i - 1

		for j >= 0 && T[j].Total < temp.Total {
			T[j+1] = T[j]
			j = j - 1
		}
		T[j+1] = temp
	}
}

//PROCEDURE FITUR DATA OBAT

/* IS : Array obat A dan jumlah data n tersedia.
   FS : Menampilkan seluruh data obat yang tersimpan.
*/
func lihatObat(A ArrObat, n int) {
	var i int
	if n == 0 {
		fmt.Println("Belum ada data obat")
	} else {
		fmt.Println()
		fmt.Println("DAFTAR OBAT")
		fmt.Printf("%-3s%-17s%-10s%-5s\n", "No", "Nama", "Harga", "Stok")
		for i = 0; i < n; i++ {
			fmt.Printf("%-3d%-17s%-10d%-5d\n", i+1, A[i].Nama, A[i].Harga, A[i].Stok)
		}
	}
}

/* IS : Array obat A dan jumlah data n tersedia, kapasitas belum penuh.
   FS : Data obat baru ditambahkan ke array jika valid.
*/
func tambahObat(A *ArrObat, n *int) {
	var x Obat
	fmt.Print("Nama Obat : ")
	fmt.Scan(&x.Nama)

	fmt.Print("Harga : ")
	fmt.Scan(&x.Harga)

	fmt.Print("Stok Awal : ")
	fmt.Scan(&x.Stok)
	
	if x.Harga<= 0 {
		fmt.Println("Harga harus lebih dari 0")
	} else if x.Stok < 0 {
		fmt.Println("Stok tidak boleh negatif")
	} else if *n >= NMAX {
		fmt.Println("Data Penuh")
	} else if sequentialSearch(*A, *n, x.Nama) != -1 {
		fmt.Println("Obat sudah ada")
	} else {
		A[*n] = x
		*n = *n + 1
		fmt.Println("Obat berhasil ditambahkan")
	}
}


/* IS : Nama obat dan jumlah stok tambahan diinput pengguna.
   FS : Stok obat bertambah jika obat ditemukan dan jumlah valid.
*/
func tambahStok(A *ArrObat, n int) {
	var nama string
	var idx, jumlah int
	fmt.Print("Nama Obat : ")
	fmt.Scan(&nama)
	idx = sequentialSearch(*A, n, nama)
	if idx == -1 {
		fmt.Println("Obat tidak ditemukan")
	} else {
		fmt.Print("Jumlah Tambahan : ")
		fmt.Scan(&jumlah)
		if jumlah <= 0 {
			fmt.Println("Jumlah harus lebih dari 0")
		} else {
			A[idx].Stok = A[idx].Stok + jumlah
			fmt.Println("Stok berhasil ditambahkan")
		}
	}
}

/* IS : Nama obat yang akan dihapus diinput pengguna.
   FS : Data obat dihapus dari array jika ditemukan.
*/
func hapusObat(A *ArrObat, n *int, T ArrTransaksi, m int) {
	var nama string
	var idx, i int
	var adaTransaksi bool

	selectionSortNama(A, *n)

	fmt.Print("Nama Obat : ")
	fmt.Scan(&nama)

	idx = binarySearch(*A, *n, nama)

	if idx == -1 {
		fmt.Println("Obat tidak ditemukan")
	} else {

		// cek apakah obat pernah ditransaksikan
		adaTransaksi = false
		for i = 0; i < m; i++ {
			if T[i].NamaObat == nama {
				adaTransaksi = true
			}
		}

		if adaTransaksi {
			fmt.Println("Obat tidak dapat dihapus karena sudah pernah ditransaksikan")
		} else {

			for i = idx; i < *n-1; i++ {
				A[i] = A[i+1]
			}

			*n = *n - 1
			fmt.Println("Obat berhasil dihapus")
		}
	}
}


/* IS : Nama obat yang dicari diinput pengguna.
   FS : Informasi obat ditampilkan jika ditemukan.
*/
func cariObat(A ArrObat, n int) {
	var nama string
	var idx int

	fmt.Print("Nama Obat : ")
	fmt.Scan(&nama)

	idx = sequentialSearch(A, n, nama)

	if idx == -1 {
		fmt.Println("Obat tidak ditemukan")
	} else {
		fmt.Println("Nama :", A[idx].Nama)
		fmt.Println("Harga :", A[idx].Harga)
		fmt.Println("Stok :", A[idx].Stok)
	}
}

//PROCEDURE TRANSAKSI

/* IS : Nama obat dan jumlah pembelian diinput pengguna.
   FS : Stok berkurang dan transaksi disimpan jika pembelian valid.
*/
func beliObat(A *ArrObat, n int, T *ArrTransaksi, m *int) {
	var nama string
	var idx, jumlah, total int
	var trx Transaksi

	fmt.Print("Nama Obat : ")
	fmt.Scan(&nama)

	idx = sequentialSearch(*A, n, nama)

	if idx == -1 {
		fmt.Println("Obat tidak ditemukan")
	} else {
		fmt.Print("Jumlah Beli : ")
		fmt.Scan(&jumlah)
		if jumlah <= 0 {
			fmt.Println("Jumlah beli harus lebih dari 0")
		} else if jumlah <= A[idx].Stok {
			total = jumlah * A[idx].Harga
			
			A[idx].Stok = A[idx].Stok - jumlah
			
			trx.NamaObat = A[idx].Nama
			trx.Jumlah = jumlah
			trx.Total = total
			
			T[*m] = trx
			*m = *m + 1
			
			fmt.Println("===== STRUK PEMBELIAN =====")
			fmt.Println("Obat :", trx.NamaObat)
			fmt.Println("Jumlah :", trx.Jumlah)
			fmt.Println("Total :", trx.Total)
		} else {
			fmt.Println("Stok tidak mencukupi")
		}
	}
}

/* IS : Data transaksi tersedia.
   FS : Menampilkan laporan transaksi yang telah diurutkan berdasarkan total.
*/
func laporanTransaksi(T *ArrTransaksi, m int) {
	var i int

	if m == 0 {
		fmt.Println("Belum ada transaksi")
	} else {
		insertionSortTransaksi(T, m)
		fmt.Println("Nama\tJumlah\tTotal")
		for i = 0; i < m; i++ {
			fmt.Println(T[i].NamaObat, "\t", T[i].Jumlah, "\t", T[i].Total)
		}
	}
}

